// ================================================================
//  CS2 COMPETITIVE AUTOEXEC — Evidence-Tiered 2026 Pass
//  Generated by: CS2 Optimization Suite (github.com/…/cs2-opt)
//
//  Based on: current CS2 convar surface, Valve patch notes through
//  March 2026, prosettings.net aggregation, and community
//  benchmarking/research (ThourCS2, djdallmann, Blur Busters, ArminC).
//
//  Structure:
//    1. Network & Interpolation
//    2. Engine & FPS
//    3. Mouse & Input
//    4. Audio — HRTF Stack
//    5. Audio — Volumes & Music
//    6. Video & Rendering
//    7. Gameplay & Prediction
//    8. HUD & UI
//    9. Radar
//   10. Viewmodel
//   11. Crosshair
//   12. Binds
//   13. Persist
//
//  Usage:
//    1. Copy this file to: <Steam>\steamapps\common\Counter-Strike Global Offensive\game\csgo\cfg\
//    2. Rename to autoexec.cfg (or keep .example and exec autoexec.cfg.example)
//    3. Set launch options: -console +exec autoexec.cfg
//    4. Customize sections marked *** PERSONAL *** to your preference
//
//  Debunked launch options (do NOT use):
//    -novid (no intro video exists in CS2)
//    -nojoy (zero measurable impact)
//    -high (non-persistent — use IFEO PerfOptions instead)
//    -forcenovsync (redundant with in-game setting)
//    -softparticlesdefaultoff (Source 1 only — unparsed by CS2)
//    -refresh N (uses Windows display setting)
//    -tickrate 128 (no-op in CS2 sub-tick)
//    -threads N (Valve explicitly warns against — reduces performance)
//    +cl_forcepreload 1 (Source 1 behavior — causes VRAM spike in CS2)
//    +mat_queue_mode 2 (Source 1 only — dead CVar)
// ================================================================


// ── 1. NETWORK & INTERPOLATION ──────────────────────────────────
//
//    Core networking stack. cl_interp_ratio/cl_interp are deprecated
//    in CS2 sub-tick but kept as belt-and-suspenders (harmless).
//
//    Sub-tick context: CS2 records inputs with sub-tick timestamps,
//    so the server resolves actions at higher precision than the tick
//    rate. cl_net_buffer_ticks is the actual latency control now.
//
//    Situational overrides: exec net_stable / net_unstable / net_highping / net_bad

rate "1000000"                                  // Max receive bandwidth (786432 was a UI bug — real cap is 1M)
cl_interp_ratio "1"                             // Deprecated in sub-tick; kept for safety
cl_interp "0"                                   // Deprecated in sub-tick; kept for safety
cl_updaterate "128"                             // Belt-and-suspenders; server controls actual rate
cl_net_buffer_ticks "0"                         // Minimum receive buffer (0 = lowest latency)
cl_net_buffer_ticks_use_interp "1"              // Link buffer ticks to interp setting
cl_tickpacket_desired_queuelength "0"           // Minimum queue depth
cl_timeout "30"                                 // Disconnect timeout (seconds)
cl_resend "0.5"                                 // Retry spread (seconds)
net_client_steamdatagram_enable_override "1"    // Force Valve SDR relay (DDoS protection + better routing)
mm_dedicated_search_maxping "80"                // Server search max ping (25 is too restrictive in most regions)
mm_session_search_qos_timeout "20"              // Faster QoS timeout for matchmaking


// ── 2. ENGINE & FPS ─────────────────────────────────────────────

engine_low_latency_sleep_after_client_tick "1"  // Current low-latency suite default; current public convar text ties it to r_low_latency
engine_no_focus_sleep "0"                       // Don't throttle when alt-tabbed
fps_max "0"                                     // Uncapped (lowest input latency — cap only if GPU thermal issues)
fps_max_ui "200"                                // Cap menus at 200 (saves GPU heat, no benefit above)
fps_max_tools "144"                             // Cap tools/workshop
con_enable "1"                                  // Console enabled


// ── 3. MOUSE & INPUT ────────────────────────────────────────────

// *** PERSONAL *** — Sensitivity
//   Formula: eDPI = DPI x sensitivity
//   Pro median: ~860 eDPI (prosettings.net, Mar 2026)
//   Examples: 400 DPI x 2.0 = 800 | 800 DPI x 1.0 = 800 | 1600 DPI x 0.5 = 800
sensitivity "1.0"                               // ← Set your sensitivity here

// Raw input & acceleration disable
m_rawinput "1"                                  // Documentation/forward-compatibility stub (current CS2 builds already force raw input)
m_mouseaccel1 "0"                               // Disable engine acceleration threshold 1
m_mouseaccel2 "0"                               // Disable engine acceleration threshold 2
m_customaccel "0"                               // Disable custom acceleration curve
m_yaw "0.022"                                   // 1:1 yaw scaling (default — do not change)
m_pitch "0.022"                                 // 1:1 pitch scaling (default — do not change)
mouse_inverty "false"                           // No inversion

// Zoom / Sniper
zoom_sensitivity_ratio "1.0"                    // 1:1 scoped sensitivity (alt: 0.82 for consistent cm/360 across zoom levels)
cl_debounce_zoom "true"                         // Prevent zoom cycling on hold
cl_sniper_auto_rezoom "true"                    // Auto-rezoom after AWP shot (false = manual rezoom for peek shots)
cl_sniper_delay_unscope "0"                     // No artificial unscope delay

// Peripherals
joystick "false"                                // No joystick input conflicts
input_filter_relative_analog_inputs "false"     // No mouse input filtering

// Input methods
option_duck_method "0"                          // Hold-to-duck (0) vs toggle (1)
option_speed_method "0"                         // Hold-to-walk (0) vs toggle (1)


// ── 4. AUDIO — HRTF STACK ──────────────────────────────────────
//
//    Headphone-focused spatial chain used by this suite:
//      1. speaker_config 1    — headphone mode
//      2. snd_spatialize_lerp 0 — suite default for the current headphone/spatial path
//      3. perspective correction on
//
//    The repo no longer claims that a separate snd_use_hrtf toggle exists in
//    the current public convar surface. These settings are kept as a
//    headphone-focused competitive baseline, not a statement about hidden or
//    undocumented engine toggles.
//
//    The legacy headphone geometry CVars (snd_headphone_pan_exponent,
//    snd_headphone_pan_radial_weight, snd_front/rear_headphone_position)
//    are BYPASSED when spatialize_lerp = 0 — they only feed the stereo
//    panner which HRTF replaces. Omitted intentionally.

// Headphone-focused spatial defaults
speaker_config "1"                              // Headphone mode
snd_spatialize_lerp "0"                         // Suite default for the current headphone/spatial path

// HRTF enhancement
snd_steamaudio_enable_perspective_correction "1" // Perspective correction for movement and head rotation
snd_steamaudio_enable_reverb "0"                // Disable room reverb — masks footstep transients and muddies HRTF cues
snd_headphone_eq "0"                            // Natural EQ (current community-preferred default)
                                                // Alt: "1" (Crisp) boosts footstep frequencies

// Audio system
snd_mixahead "0.05"                             // Stability-oriented suite default; current engine default is much lower
voice_always_sample_mic "1"                     // Keep mic hot (no activation delay)
snd_mute_losefocus "0"                          // Don't mute when alt-tabbed

// ── 4b. REFERENCE: ALTERNATIVE STEREO TUNING ──────────────────
//
//    If you prefer a more traditional stereo presentation, use this as a
//    manual starting point and benchmark/listen on your own system.
//
//    Stereo gives you:
//      + Left/right positioning (pan-law based)
//      + Cleaner, less "processed" sound
//      - No vertical audio (above/below sound identical)
//      - No front/back disambiguation (both are center)
//      - No head-rotation correction
//
//    The headphone geometry CVars below are ONLY active when
//    snd_spatialize_lerp > 0 (i.e., legacy stereo is in use).
//    With HRTF on (lerp = 0), they are completely ignored.
//
//    To switch: comment HRTF section, uncomment this block, restart CS2.
//
// ── Core ──
// speaker_config "1"                            // Headphones mode (still required for proper stereo panning)
// snd_spatialize_lerp "1"                       // Heavier legacy-stereo blend
//
// ── Headphone geometry (only active with stereo panner) ──
//    pan_exponent controls the L/R falloff curve:
//      1.0 = linear (default, natural)
//      1.2 = slightly wider center image (subtle, some pros prefer)
//      2.0 = aggressive center focus (not recommended — degrades spatial accuracy)
//    radial_weight blends between angular and radial panning models:
//      0.0 = pure angular (default, most intuitive)
//      1.0 = pure radial (sounds cluster toward center)
//    front/rear_headphone_position sets the virtual speaker angle:
//      90.0 = default neutral (ears at 90 degrees)
//      Lower values narrow the soundstage
//
// snd_headphone_pan_exponent "1.0"              // Linear panning — most natural L/R distribution
// snd_headphone_pan_radial_weight "0.0"         // Pure angular — direction matches expectation
// snd_front_headphone_position "90.0"           // Neutral front soundstage
// snd_rear_headphone_position "90.0"            // Neutral rear soundstage
//
// ── Stereo enhancement ──
// snd_steamaudio_enable_perspective_correction "0" // Optional if you dislike the default spatial presentation
// snd_steamaudio_enable_reverb "0"              // Still off for competitive (masks footsteps regardless of HRTF)
// snd_headphone_eq "1"                          // Crisp EQ alternative — boosts footstep frequencies
//
// ── Audio system ──
// snd_mixahead "0.025"                          // Lower buffer variant — benchmark/listen before keeping it
// voice_always_sample_mic "1"
// snd_mute_losefocus "0"


// ── 5. AUDIO — VOLUMES & MUSIC ──────────────────────────────────
//
//    HRTF encodes direction via subtle frequency differences between
//    ears. Loud competing audio (VOIP, music) masks these cues.
//    Strategy: kill all non-essential audio, reduce VOIP ducking impact.

// Master / Voice
snd_gamevolume "1.0"                            // Master volume (control at OS/headset level)
snd_gamevoicevolume "1.0"                       // System voices neutral
snd_voipvolume "0.5"                            // VOIP lower — preserves HRTF spatial cues during comms
volume "1.0"

// Ducking — tuned for HRTF preservation
//   Default ducking drops game audio to 0.55 during VOIP, destroying
//   HRTF spatial info mid-callout. Higher ducktovolume + higher
//   threshold = spatial cues survive teammate comms.
snd_ducktovolume "0.75"                         // Only 25% duck (default 0.55 = 45% — too aggressive for HRTF)
snd_duckerattacktime "0.5"                      // Quick onset
snd_duckerreleasetime "1.5"                     // Fast recovery — spatial awareness back sooner after callout
snd_duckerthreshold "0.25"                      // Higher threshold = only loud VOIP triggers ducking

// Music — all off (any music masks HRTF frequency cues)
snd_musicvolume "0"                             // Master music off (overrides per-category if >0)
snd_menumusic_volume "0"
snd_roundstart_volume "0"
snd_roundend_volume "0"
snd_roundaction_volume "0"
snd_mvp_volume "0"
snd_mapobjective_volume "0"
snd_tensecondwarning_volume "0.1"               // 10-second warning kept (tactical cue — brief, doesn't mask)
snd_deathcamera_volume "0"

// Deathcam mix — minimize audio disruption so you can relay positions
cl_disable_deathcam_audio_mix_fade_out "1"      // No automatic deathcam ducking
cl_deathcam_audio_mix_phase1_fade_amount "0.05" // Minimal fade — keep hearing enemies for callouts
cl_deathcam_audio_mix_phase1_fade_time "0.5"
cl_deathcam_audio_mix_phase2_fade_amount "0.15"
cl_deathcam_audio_mix_phase2_fade_time "0.3"

// Communication & muting
snd_mute_mvp_music_live_players "1"             // Mute MVP music while players alive (prevents masking footsteps)
cl_mute_all_but_friends_and_party "0"           // Hear all teammates
cl_mute_enemy_team "1"                          // Mute enemy voice (no tilt/distraction)
cl_player_ping_mute "1"                         // Mute ping sound (visual ping stays)
cl_clutch_mode "0"                              // Clutch mode off (toggle via bind as needed)
cl_embedded_stream_audio_volume "0"             // Mute embedded Twitch/event stream audio
tv_nochat "1"                                   // Mute GOTV spectator chat

// Invites / Social
cl_invites_only_mainmenu "1"                    // Block invite popups during matches
cl_invites_only_friends "1"                     // Only accept invites from friends


// ── 6. VIDEO & RENDERING ────────────────────────────────────────

r_player_visibility_mode "1"                    // Boost Player Contrast (current suite default; benchmark-dependent)
r_fullscreen_gamma "2.2"                        // sRGB standard (adjust 2.0-2.4 to taste — lower = brighter)
mat_monitorgamma_tv_enabled "0"                 // Disable TV gamma curve
r_drawtracers_firstperson "0"                   // No first-person tracers (visual noise)
r_show_build_info "0"                           // No build overlay
cl_showfps "0"                                  // FPS counter off (use "1" or "3" for tuning)

// Telemetry HUD — all off (CS2 replacement for removed net_graph)
//   Enable individually for debugging: 1 = show
cl_hud_telemetry_frametime_show "0"
cl_hud_telemetry_ping_show "0"
cl_hud_telemetry_net_misdelivery_show "0"
cl_hud_telemetry_net_quality_graph_show "0"
cl_hud_telemetry_serverrecvmargin_graph_show "0"

// In-game video settings (set via menu — documented for reproducibility):
//
//   Low-end (GTX 1650/1660):
//     MSAA: Off | Shadows: Medium | Texture: Low | AF: 2x | AO: Off | HDR: Performance
//
//   Mid-range (RTX 3060/4060):
//     MSAA: 2x | Shadows: Medium | Texture: Medium | AF: 8x | AO: Off | HDR: Performance
//
//   High-end (RTX 4070+):
//     MSAA: 4x | Shadows: Medium | Texture: High | AF: 16x | AO: Off | HDR: Performance
//
//   All tiers:
//     Display Mode: Fullscreen | V-Sync: Disabled | NVIDIA Reflex: Enabled
//     Global Shadow Quality: Low | Shader Detail: Low | Particle Detail: Low
//     HDR: Performance (suite default; benchmark-dependent)
//     FSR: Disabled (native sharpness) | Dynamic Shadows: All (positional info)


// ── 7. GAMEPLAY & PREDICTION ────────────────────────────────────
//
//    Damage prediction: 95% of 120 tracked pros disable body/head
//    shot prediction (ThourCS2, Feb 2025). Phantom dinks cause fatal
//    target-switching errors. Valve acknowledged the issue (Nov 2024).

cl_predict_body_shot_fx "0"                     // OFF — fake hit feedback at >0 ping
cl_predict_head_shot_fx "0"                     // OFF — phantom dinks cause fatal target-switching errors
cl_predict_kill_ragdolls "0"                    // No predicted ragdolls (reduce visual noise after kills)
cl_disable_ragdolls "1"                         // No corpse physics (CPU savings + less visual clutter)
cl_autowepswitch "0"                            // No auto weapon switch on pickup (competitive standard)
cl_silencer_mode "0"                            // Prevent accidental silencer detach (M4A1-S/USP-S)
cl_dm_buyrandomweapons "0"                      // Pick own weapon in DM (no random spawn weapon)
gameinstructor_enable "0"                       // No tutorial hints
cl_autohelp "0"                                 // No help text
lobby_default_privacy_bits2 "0"                 // Private lobby by default
cl_join_advertise "2"                           // Friends can see/join your server (0 = invisible)


// ── 8. HUD & UI ─────────────────────────────────────────────────

hud_scaling "1.0"                               // Max HUD size for readability
safezonex "1.0"                                 // No overscan
safezoney "1.0"                                 // No overscan
cl_hud_color "0"                                // Team color HUD (0-10, see in-game menu)
cl_showloadout "true"                           // Show loadout (prevents misbuys)
cl_draw_only_deathnotices "0"                   // Full HUD (1 = minimal HUD for streaming/clips)
hud_showtargetid "1"                            // Show target name/HP on crosshair hover
cl_hide_avatar_images "2"                       // Avatars: 0=all, 1=none, 2=friends only
cl_compass_enabled "0"                          // Hide compass (radar is sufficient)
cl_show_clan_in_death_notice "0"                // No clan tags in kill feed (cleaner parsing)
cl_weapon_selection_rarity_color "0"            // No skin rarity glow on weapon HUD icons

// Teammate display
cl_teamid_overhead_colors_show "1"              // Overhead IDs in team color
cl_teamid_overhead_mode "2"                     // 0=Off, 1=Pips, 2=Pips+Name+Equipment
cl_teammate_colors_show "1"                     // Individual team colors (show color dots)
cl_allow_animated_avatars "0"                   // No animated avatars (reduces distraction)
cl_teamcounter_playercount_instead_of_avatars "1" // Player count instead of avatar row
player_nevershow_communityservermessage "1"      // Suppress community server messages
cl_sanitize_player_names "0"                    // Real player names (1 = anonymized)
cl_sanitize_muted_players "1"                   // Anonymize muted players

// Buy menu
cl_use_opens_buy_menu "0"                       // Prevent E key opening buy menu in buy zone
cl_buywheel_nonumberpurchasing "1"              // Number keys won't buy (prevents misbuys when switching weapons)

// Spectator
cl_spec_show_bindings "0"                       // Hide spectator control hints
cl_obs_interp_enable "1"                        // Smooth observer transitions
cl_showpos "0"                                  // Position off (1 = show coordinates)
developer "0"                                   // No dev log (1 = console spam)


// ── 9. RADAR ────────────────────────────────────────────────────
//
//    *** PERSONAL *** — Radar is highly preference-dependent.
//    These values show the full map at a small size. Adjust to taste.

cl_radar_always_centered "0"                    // Not centered — more map context visible
cl_radar_scale "0.4"                            // Zoom level (lower = more zoomed out)
cl_radar_rotate "1"                             // Rotate with player view
cl_radar_icon_scale_min "0.6"                   // Player icon minimum size
cl_radar_square_with_scoreboard "true"          // Square radar when scoreboard is open
cl_hud_radar_scale "1.0"                        // Radar HUD element size


// ── 10. VIEWMODEL ──────────────────────────────────────────────
//
//    *** PERSONAL *** — Viewmodel is purely cosmetic preference.
//    viewmodel_recoil affects visual clarity during spray transfers.
//    Preset positions: 1=Desktop, 2=Couch, 3=Classic

viewmodel_recoil "0"                            // No weapon kick animation during spray (better target visibility)
viewmodel_fov "68"                              // Wider FOV — less weapon obstruction (54-68 range)
viewmodel_offset_x "2.5"                        // Horizontal offset (-2 to 2.5)
viewmodel_offset_y "0"                          // Depth offset (-2 to 2)
viewmodel_offset_z "-1.5"                       // Vertical offset (-2 to 2)
viewmodel_presetpos "0"                         // 0=Custom (uses offsets above), 1/2/3=preset


// ── 11. CROSSHAIR ──────────────────────────────────────────────
//
//    *** PERSONAL *** — Crosshair is the most individual setting.
//    Below is a neutral competitive starting point (small static green).
//    Use the in-game crosshair generator or workshop maps to customize.
//    Import pro crosshairs via share codes: Settings > Crosshair > Share

// Style & behavior
cl_crosshairstyle "4"                           // Static crosshair (4=static, 2/3=dynamic)
cl_crosshairalpha "255"                         // Full opacity (0-255)
cl_crosshairdot "0"                             // No center dot (1=show)
cl_crosshairusealpha "1"                        // Use alpha channel
cl_crosshairgap_useweaponvalue "0"              // Fixed gap (1=weapon-dependent gap)
cl_crosshair_recoil "0"                         // No recoil coupling (1=crosshair follows recoil)

// Sniper scope
cl_crosshair_sniper_width "1"                   // Scope line width (1-3)
cl_sniper_show_inaccuracy "0"                   // No scope bloom indicator (Oct 2025 CVar — cleaner scope)
cl_crosshair_sniper_show_normal_inaccuracy "0"  // No standing inaccuracy blur in scope
cl_crosshair_friendly_warning "1"               // Show friendly fire warning (0=off if distracting)

// Appearance — neutral green static (customize to preference)
cl_crosshair_drawoutline "1"                    // Outline for visibility on bright surfaces
cl_crosshair_outlinethickness "1"               // Thin outline
cl_crosshaircolor "1"                           // 1=Green (0=Red, 2=Yellow, 3=Blue, 4=Cyan, 5=Custom RGB)
cl_crosshairgap "-1.5"                          // Gap between arms (-5 to 5)
cl_crosshairsize "2"                            // Arm length (0.5-5)
cl_crosshairthickness "1"                       // Arm thickness (0.5-3)


// ── 12. BINDS ──────────────────────────────────────────────────
//
//    *** PERSONAL *** — Keybinds are entirely preference.
//    Below are competitive defaults. Customize freely.
//
//    Tips:
//      - Unbind MWHEELUP/DOWN to prevent accidental weapon scrolling
//      - Direct grenade binds (slot6-10) are faster than cycling
//      - Side mouse buttons work well for voice/ping
//      - Arrow keys / numpad are common for buy binds

// Core
bind "MOUSE1" "+attack"
bind "MOUSE2" "+attack2"
bind "`" "toggleconsole"
bind "ESCAPE" "cancelselect"
bind "TAB" "+showscores"
bind "b" "buymenu"

// Weapons — direct slot binds (unbind scroll wheel)
unbind "MWHEELUP"
unbind "MWHEELDOWN"
bind "1" "slot1"                                // Primary
bind "2" "slot2"                                // Pistol
bind "3" "slot3"                                // Knife
bind "4" "slot4"                                // Grenade cycle
bind "5" "slot5"                                // C4/Defuser

// Grenades — direct binds (faster than cycling with slot4)
//   Customize these keys to your preference. Common layouts:
//   ZXCV, 456, or mouse side buttons.
// bind "KEY" "slot6"                            // HE Grenade
// bind "KEY" "slot7"                            // Flashbang
// bind "KEY" "slot8"                            // Smoke
// bind "KEY" "slot10"                           // Molotov / Incendiary

// Buy binds — example layout (customize to preference)
//   Use side-specific buys: "BUY ak47; BUY m4a1_silencer" buys AK on T, M4 on CT
// bind "KEY" "BUY vesthelm"
// bind "KEY" "BUY ak47; BUY m4a1_silencer"
// bind "KEY" "BUY awp"
// bind "KEY" "BUY defuser"
// bind "KEY" "BUY hegrenade"
// bind "KEY" "BUY flashbang"
// bind "KEY" "BUY smokegrenade"
// bind "KEY" "BUY molotov"

// Communication
bind "MOUSE3" "player_ping"                     // Team ping (middle click)
// bind "KEY" "+voicerecord"                     // Push-to-talk

// Cleanup — unbind keys you don't use to prevent accidental input
// unbind "F1"
// unbind "F2"


// ── 13. PERSIST ────────────────────────────────────────────────

host_writeconfig
